Options -MultiViews
RewriteEngine On

# ── 1. Redirect /page.html  →  /page  (301 permanent) ──────────────────────
# Ai đã bookmark hay share link .html sẽ tự được redirect sang URL sạch.
RewriteCond %{THE_REQUEST} \s/(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [NE,L,R=301]

# ── 2. /page  →  serve page.html nội bộ (không đổi URL trên browser) ───────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
